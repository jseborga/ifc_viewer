<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="module_category_bim" model="ir.module.category">
        <field name="name">BIM</field>
        <field name="sequence">35</field>
    </record>

    <record id="group_bim_user" model="res.groups">
        <field name="name">BIM User</field>
        <field name="category_id" ref="odoo_bim_ifc_tiles.module_category_bim"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_bim_manager" model="res.groups">
        <field name="name">BIM Manager</field>
        <field name="category_id" ref="odoo_bim_ifc_tiles.module_category_bim"/>
        <field name="implied_ids" eval="[(4, ref('odoo_bim_ifc_tiles.group_bim_user'))]"/>
    </record>
</odoo>
