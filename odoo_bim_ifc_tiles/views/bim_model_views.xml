<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_bim_model_list" model="ir.ui.view">
        <field name="name">bim.model.list</field>
        <field name="model">bim.model</field>
        <field name="arch" type="xml">
            <list string="BIM Models">
                <field name="name"/>
                <field name="discipline"/>
                <field name="project_id"/>
                <field name="task_id"/>
                <field name="active_version_id"/>
                <field name="latest_status"/>
                <field name="version_count"/>
            </list>
        </field>
    </record>

    <record id="view_bim_model_form" model="ir.ui.view">
        <field name="name">bim.model.form</field>
        <field name="model">bim.model</field>
        <field name="arch" type="xml">
            <form string="BIM Model">
                <header>
                    <button name="action_view_versions" type="object" string="Versions" class="oe_highlight"/>
                    <button
                        name="action_open_active_viewer"
                        type="object"
                        string="Open Viewer"
                        class="oe_highlight"
                        invisible="not active_version_can_open_viewer"
                    />
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="discipline"/>
                            <field name="active_version_id"/>
                            <field name="active_version_can_open_viewer" invisible="1"/>
                        </group>
                        <group>
                            <field name="project_id"/>
                            <field name="task_id"/>
                            <field name="version_count" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                    <notebook>
                        <page string="Versions">
                            <field name="version_ids" context="{'default_bim_model_id': id}">
                                <list>
                                    <field name="name" readonly="1"/>
                                    <field name="source_filename" readonly="1"/>
                                    <field name="status"/>
                                    <field name="uploaded_on" readonly="1"/>
                                    <field name="tileset_url"/>
                                    <field name="can_open_viewer" column_invisible="1"/>
                                    <button
                                        name="action_open_viewer"
                                        type="object"
                                        string="Open Viewer"
                                        class="oe_link"
                                        invisible="not can_open_viewer"
                                    />
                                </list>
                                <form string="BIM Version">
                                    <sheet>
                                        <group>
                                            <group>
                                                <field name="bim_model_id" readonly="1"/>
                                                <field name="name" readonly="1"/>
                                                <field name="ifc_upload" filename="ifc_upload_filename"/>
                                                <field name="ifc_upload_filename" invisible="1"/>
                                                <field name="ifc_attachment_id" readonly="1"/>
                                                <field name="source_filename" readonly="1"/>
                                                <field name="ifc_schema"/>
                                            </group>
                                            <group>
                                                <field name="status"/>
                                                <field name="uploaded_by" readonly="1"/>
                                                <field name="uploaded_on" readonly="1"/>
                                                <field name="tileset_url"/>
                                                <field name="can_open_viewer" invisible="1"/>
                                            </group>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
</odoo>
