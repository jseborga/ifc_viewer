<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_bim_version_list" model="ir.ui.view">
        <field name="name">bim.model.version.list</field>
        <field name="model">bim.model.version</field>
        <field name="arch" type="xml">
            <list string="BIM Versions">
                <field name="name"/>
                <field name="bim_model_id"/>
                <field name="source_filename"/>
                <field name="status"/>
                <field name="uploaded_by"/>
                <field name="uploaded_on"/>
                <field name="tileset_url"/>
                <field name="can_open_viewer" column_invisible="1"/>
                <button
                    name="action_open_viewer"
                    type="object"
                    string="Open Viewer"
                    class="oe_link"
                    invisible="not can_open_viewer"
                />
            </list>
        </field>
    </record>

    <record id="view_bim_version_form" model="ir.ui.view">
        <field name="name">bim.model.version.form</field>
        <field name="model">bim.model.version</field>
        <field name="arch" type="xml">
            <form string="BIM Version">
                <header>
                    <button
                        name="action_queue_conversion"
                        type="object"
                        string="Queue Conversion"
                        class="oe_highlight"
                        invisible="not ifc_attachment_id or status in ['queued', 'processing']"
                    />
                    <button
                        name="action_open_viewer"
                        type="object"
                        string="Open Viewer"
                        class="oe_highlight"
                        invisible="not can_open_viewer"
                    />
                    <button name="action_set_active" type="object" string="Set Active"/>
                    <field
                        name="status"
                        widget="statusbar"
                        statusbar_visible="draft,queued,processing,ready,error"
                    />
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="bim_model_id"/>
                            <field name="name" readonly="1"/>
                            <field name="ifc_upload" filename="ifc_upload_filename"/>
                            <field name="ifc_upload_filename" invisible="1"/>
                            <field name="ifc_attachment_id"/>
                            <field name="source_filename"/>
                            <field name="ifc_schema"/>
                        </group>
                        <group>
                            <field name="uploaded_by" readonly="1"/>
                            <field name="uploaded_on" readonly="1"/>
                            <field name="tileset_url"/>
                            <field name="conversion_job_ref" readonly="1"/>
                            <field name="can_open_viewer" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Conversion">
                            <group>
                                <group>
                                    <field name="georef_lon"/>
                                    <field name="georef_lat"/>
                                    <field name="georef_height"/>
                                </group>
                                <group>
                                    <field name="heading"/>
                                    <field name="pitch"/>
                                    <field name="roll"/>
                                </group>
                            </group>
                            <group>
                                <field name="conversion_requested_on" readonly="1"/>
                                <field name="conversion_finished_on" readonly="1"/>
                            </group>
                            <group>
                                <field name="conversion_log" widget="text"/>
                                <field name="error_message" widget="text"/>
                            </group>
                        </page>
                        <page string="Metadata">
                            <field name="metadata_json" widget="text"/>
                        </page>
                        <page string="Snapshots">
                            <field name="snapshot_ids" context="{'default_version_id': id}">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="author_id" readonly="1"/>
                                    <field name="image_attachment_id"/>
                                    <field name="create_date" readonly="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Comments">
                            <field name="comment_ids" context="{'default_version_id': id}">
                                <list editable="bottom">
                                    <field name="author_id" readonly="1"/>
                                    <field name="element_guid"/>
                                    <field name="comment"/>
                                    <field name="create_date" readonly="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
</odoo>
