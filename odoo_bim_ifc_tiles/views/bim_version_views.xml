<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_bim_version_list" model="ir.ui.view">
        <field name="name">bim.model.version.list</field>
        <field name="model">bim.model.version</field>
        <field name="arch" type="xml">
            <list string="BIM Versions">
                <field name="name"/>
                <field name="bim_model_id"/>
                <field name="source_filename"/>
                <field name="status"/>
                <field name="validation_status"/>
                <field name="element_count"/>
                <field name="uploaded_by"/>
                <field name="uploaded_on"/>
                <field name="tileset_url"/>
                <field name="can_open_viewer" column_invisible="1"/>
                <button
                    name="action_open_viewer"
                    type="object"
                    string="Open Viewer"
                    class="oe_link"
                    invisible="not can_open_viewer"
                />
            </list>
        </field>
    </record>

    <record id="view_bim_version_form" model="ir.ui.view">
        <field name="name">bim.model.version.form</field>
        <field name="model">bim.model.version</field>
        <field name="arch" type="xml">
            <form string="BIM Version">
                <header>
                    <button
                        name="action_queue_conversion"
                        type="object"
                        string="Queue Conversion"
                        class="oe_highlight"
                        invisible="not ifc_attachment_id or status in ['queued', 'processing']"
                    />
                    <button
                        name="action_open_viewer"
                        type="object"
                        string="Open Viewer"
                        class="oe_highlight"
                        invisible="not can_open_viewer"
                    />
                    <button name="action_set_active" type="object" string="Set Active"/>
                    <field
                        name="status"
                        widget="statusbar"
                        statusbar_visible="draft,queued,processing,ready,error"
                    />
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="bim_model_id"/>
                            <field name="name" readonly="1"/>
                            <field name="ifc_upload" filename="ifc_upload_filename"/>
                            <field name="ifc_upload_filename" invisible="1"/>
                            <field name="ifc_attachment_id"/>
                            <field name="source_filename"/>
                            <field name="ifc_schema"/>
                        </group>
                        <group>
                            <field name="uploaded_by" readonly="1"/>
                            <field name="uploaded_on" readonly="1"/>
                            <field name="tileset_url"/>
                            <field name="visualization_format" readonly="1"/>
                            <field name="tileset_spec_version" readonly="1"/>
                            <field name="validation_status" readonly="1"/>
                            <field name="element_count" readonly="1"/>
                            <field name="metadata_truncated" readonly="1"/>
                            <field name="conversion_job_ref" readonly="1"/>
                            <field name="can_open_viewer" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Conversion">
                            <group>
                                <group>
                                    <field name="georef_lon"/>
                                    <field name="georef_lat"/>
                                    <field name="georef_height"/>
                                </group>
                                <group>
                                    <field name="heading"/>
                                    <field name="pitch"/>
                                    <field name="roll"/>
                                </group>
                            </group>
                            <group>
                                <field name="conversion_requested_on" readonly="1"/>
                                <field name="conversion_finished_on" readonly="1"/>
                                <field name="validation_checked_on" readonly="1"/>
                                <field name="metadata_extracted_on" readonly="1"/>
                            </group>
                            <group>
                                <field name="validation_summary" widget="text" readonly="1"/>
                                <field name="conversion_log" widget="text"/>
                                <field name="error_message" widget="text"/>
                            </group>
                        </page>
                        <page string="Metadata Summary">
                            <group>
                                <field name="metadata_json" widget="text" readonly="1"/>
                                <field name="validation_report_json" widget="text" readonly="1"/>
                                <field name="visual_package_manifest_json" widget="text" readonly="1"/>
                            </group>
                        </page>
                        <page string="Elements">
                            <field name="element_ids" context="{'default_version_id': id}">
                                <list create="0" delete="0" edit="0">
                                    <field name="global_id"/>
                                    <field name="name"/>
                                    <field name="ifc_class"/>
                                    <field name="level_name"/>
                                    <field name="system_name"/>
                                    <field name="discipline"/>
                                    <field name="property_count"/>
                                </list>
                                <form string="BIM Element">
                                    <sheet>
                                        <group>
                                            <group>
                                                <field name="version_id" readonly="1"/>
                                                <field name="global_id" readonly="1"/>
                                                <field name="source_uid" readonly="1"/>
                                                <field name="name" readonly="1"/>
                                                <field name="ifc_class" readonly="1"/>
                                                <field name="object_type" readonly="1"/>
                                                <field name="predefined_type" readonly="1"/>
                                            </group>
                                            <group>
                                                <field name="level_name" readonly="1"/>
                                                <field name="system_name" readonly="1"/>
                                                <field name="discipline" readonly="1"/>
                                                <field name="material_names" readonly="1"/>
                                                <field name="is_spatial" readonly="1"/>
                                                <field name="property_count" readonly="1"/>
                                            </group>
                                        </group>
                                        <group>
                                            <field name="properties_json" widget="text" readonly="1"/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page string="Snapshots">
                            <field name="snapshot_ids" context="{'default_version_id': id}">
                                <list>
                                    <field name="screenshot_image" widget="image" options="{'size': [96, 64]}"/>
                                    <field name="name"/>
                                    <field name="author_id" readonly="1"/>
                                    <field name="note"/>
                                    <field name="annotation_count" readonly="1"/>
                                    <field name="review_comment_count" readonly="1"/>
                                    <field name="create_date" readonly="1"/>
                                </list>
                                <form string="Snapshot Review">
                                    <sheet>
                                        <group>
                                            <group>
                                                <field name="name"/>
                                                <field name="version_id" readonly="1"/>
                                                <field name="author_id" readonly="1"/>
                                                <field name="create_date" readonly="1"/>
                                                <field name="image_filename" readonly="1"/>
                                            </group>
                                            <group>
                                                <field name="annotation_count" readonly="1"/>
                                                <field name="review_comment_count" readonly="1"/>
                                                <field name="note" widget="text" placeholder="General review note for this snapshot"/>
                                            </group>
                                        </group>
                                        <separator string="Reviewed Snapshot"/>
                                        <group>
                                            <field name="screenshot_preview_html" widget="html" readonly="1" nolabel="1"/>
                                        </group>
                                        <notebook>
                                            <page string="Observation">
                                                <group>
                                                    <field name="note" widget="text" readonly="1"/>
                                                    <field name="annotation_summary" widget="text" readonly="1"/>
                                                    <field name="annotation_preview_html" widget="html" readonly="1"/>
                                                </group>
                                            </page>
                                            <page string="Review Thread">
                                                <field
                                                    name="review_comment_ids"
                                                    domain="[('parent_id', '=', False)]"
                                                    context="{'default_version_id': version_id, 'default_snapshot_id': id}"
                                                >
                                                    <list editable="bottom">
                                                        <field name="title"/>
                                                        <field name="status"/>
                                                        <field name="priority"/>
                                                        <field name="author_id" readonly="1"/>
                                                        <field name="comment"/>
                                                        <field name="review_image" widget="image" options="{'size': [96, 64]}"/>
                                                        <field name="reply_count" readonly="1"/>
                                                        <field name="create_date" readonly="1"/>
                                                    </list>
                                                    <form string="Snapshot Review Issue">
                                                        <sheet>
                                                            <group>
                                                                <group>
                                                                    <field name="title"/>
                                                                    <field name="status"/>
                                                                    <field name="priority"/>
                                                                    <field name="author_id" readonly="1"/>
                                                                </group>
                                                                <group>
                                                                    <field name="snapshot_id"/>
                                                                    <field name="version_id" readonly="1"/>
                                                                    <field name="element_guid"/>
                                                                    <field name="parent_id"/>
                                                                </group>
                                                            </group>
                                                            <group>
                                                                <field name="comment" widget="text"/>
                                                            </group>
                                                            <group>
                                                                <group>
                                                                    <field name="image_upload" filename="image_upload_filename"/>
                                                                    <field name="image_upload_filename" invisible="1"/>
                                                                    <field name="image_filename" readonly="1"/>
                                                                </group>
                                                                <group>
                                                                    <field name="image_preview_html" widget="html" readonly="1" nolabel="1"/>
                                                                </group>
                                                            </group>
                                                            <notebook>
                                                                <page string="Replies">
                                                                    <field
                                                                        name="child_ids"
                                                                        context="{'default_version_id': version_id, 'default_snapshot_id': snapshot_id, 'default_parent_id': id}"
                                                                    >
                                                                        <list editable="bottom">
                                                                            <field name="author_id" readonly="1"/>
                                                                            <field name="status"/>
                                                                            <field name="comment"/>
                                                                            <field name="review_image" widget="image" options="{'size': [72, 48]}"/>
                                                                            <field name="create_date" readonly="1"/>
                                                                        </list>
                                                                        <form string="Review Reply">
                                                                            <sheet>
                                                                                <group>
                                                                                    <group>
                                                                                        <field name="author_id" readonly="1"/>
                                                                                        <field name="status"/>
                                                                                        <field name="priority"/>
                                                                                    </group>
                                                                                    <group>
                                                                                        <field name="snapshot_id"/>
                                                                                        <field name="version_id" readonly="1"/>
                                                                                        <field name="parent_id" readonly="1"/>
                                                                                    </group>
                                                                                </group>
                                                                                <group>
                                                                                    <field name="comment" widget="text"/>
                                                                                </group>
                                                                                <group>
                                                                                    <group>
                                                                                        <field name="image_upload" filename="image_upload_filename"/>
                                                                                        <field name="image_upload_filename" invisible="1"/>
                                                                                        <field name="image_filename" readonly="1"/>
                                                                                    </group>
                                                                                    <group>
                                                                                        <field name="image_preview_html" widget="html" readonly="1" nolabel="1"/>
                                                                                    </group>
                                                                                </group>
                                                                            </sheet>
                                                                        </form>
                                                                    </field>
                                                                </page>
                                                            </notebook>
                                                        </sheet>
                                                    </form>
                                                </field>
                                            </page>
                                        </notebook>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page string="Comments">
                            <field name="comment_ids" domain="[('parent_id', '=', False)]" context="{'default_version_id': id}">
                                <list>
                                    <field name="snapshot_id"/>
                                    <field name="title"/>
                                    <field name="status"/>
                                    <field name="priority"/>
                                    <field name="author_id" readonly="1"/>
                                    <field name="element_guid"/>
                                    <field name="comment"/>
                                    <field name="review_image" widget="image" options="{'size': [72, 48]}"/>
                                    <field name="reply_count" readonly="1"/>
                                    <field name="create_date" readonly="1"/>
                                </list>
                                <form string="Review Issue">
                                    <sheet>
                                        <group>
                                            <group>
                                                <field name="title"/>
                                                <field name="status"/>
                                                <field name="priority"/>
                                                <field name="author_id" readonly="1"/>
                                            </group>
                                            <group>
                                                <field name="snapshot_id"/>
                                                <field name="version_id" readonly="1"/>
                                                <field name="element_guid"/>
                                                <field name="parent_id"/>
                                            </group>
                                        </group>
                                        <group>
                                            <field name="comment" widget="text"/>
                                        </group>
                                        <group>
                                            <group>
                                                <field name="image_upload" filename="image_upload_filename"/>
                                                <field name="image_upload_filename" invisible="1"/>
                                                <field name="image_filename" readonly="1"/>
                                            </group>
                                            <group>
                                                <field name="image_preview_html" widget="html" readonly="1" nolabel="1"/>
                                            </group>
                                        </group>
                                        <notebook>
                                            <page string="Replies">
                                                <field
                                                    name="child_ids"
                                                    context="{'default_version_id': version_id, 'default_snapshot_id': snapshot_id, 'default_parent_id': id}"
                                                >
                                                    <list editable="bottom">
                                                        <field name="author_id" readonly="1"/>
                                                        <field name="status"/>
                                                        <field name="comment"/>
                                                        <field name="review_image" widget="image" options="{'size': [72, 48]}"/>
                                                        <field name="create_date" readonly="1"/>
                                                    </list>
                                                    <form string="Review Reply">
                                                        <sheet>
                                                            <group>
                                                                <group>
                                                                    <field name="author_id" readonly="1"/>
                                                                    <field name="status"/>
                                                                    <field name="priority"/>
                                                                </group>
                                                                <group>
                                                                    <field name="snapshot_id"/>
                                                                    <field name="version_id" readonly="1"/>
                                                                    <field name="parent_id" readonly="1"/>
                                                                </group>
                                                            </group>
                                                            <group>
                                                                <field name="comment" widget="text"/>
                                                            </group>
                                                            <group>
                                                                <group>
                                                                    <field name="image_upload" filename="image_upload_filename"/>
                                                                    <field name="image_upload_filename" invisible="1"/>
                                                                    <field name="image_filename" readonly="1"/>
                                                                </group>
                                                                <group>
                                                                    <field name="image_preview_html" widget="html" readonly="1" nolabel="1"/>
                                                                </group>
                                                            </group>
                                                        </sheet>
                                                    </form>
                                                </field>
                                            </page>
                                        </notebook>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
</odoo>
